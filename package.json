{
    "name": "securitron-backend",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "imports": {
        "#src/*": "./src/*",
        "#config/*": "./shared/config/*",
        "#lib/*": "./shared/lib/*",
        "#middlewares/*": "./shared/middlewares/*"
    },
    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1",
        "dev": "pm2 start ecosystem.config.cjs --watch --env development && nginx -c $(pwd)/nginx.conf",
        "start": "pm2 start ecosystem.config.cjs --env production && nginx -c $(pwd)/nginx.conf",
        "logs": "pm2 logs",
        "logs-rest-api": "pm2 logs rest-api-server",
        "logs-live-tick": "pm2 logs live-tick-server",
        "stop": "pm2 stop ecosystem.config.cjs && nginx -c $(pwd)/nginx.conf -s stop"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/phANTom2303/securitron-backend.git"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "module",
    "bugs": {
        "url": "https://github.com/phANTom2303/securitron-backend/issues"
    },
    "homepage": "https://github.com/phANTom2303/securitron-backend#readme",
    "dependencies": {
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "express-rate-limit": "^8.2.1",
        "helmet": "^8.1.0",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "pm2": "^6.0.14",
        "redis": "^5.11.0"
    },
    "devDependencies": {
        "nodemon": "^3.1.14"
    }
}